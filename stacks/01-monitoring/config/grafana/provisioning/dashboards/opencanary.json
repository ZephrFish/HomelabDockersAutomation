{
  "title": "OpenCanary Honeypot",
  "uid": "opencanary-honeypot",
  "tags": ["security", "honeypot"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Hits (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum(count_over_time({job=\"opencanary\"} | json | src_host != \"\" [24h]))",
          "legendFormat": "Hits",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique Source IPs (24h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "count(count by (src_host) (count_over_time({job=\"opencanary\"} | json | src_host != \"\" [24h])))",
          "legendFormat": "Unique IPs",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last Hit",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "unit": "dateTimeAsLocal"
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "count_over_time({job=\"opencanary\"} | json | src_host != \"\" [1m])",
          "legendFormat": "hits",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Honeypot Events Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (logtype) (count_over_time({job=\"opencanary\"} | json | src_host != \"\" | label_format logtype=logtype [$__interval]))",
          "legendFormat": "Type {{logtype}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent Events",
      "gridPos": { "x": 0, "y": 12, "w": 16, "h": 12 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "sortBy": [{ "displayName": "Time", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "src_host" },
            "properties": [{ "id": "displayName", "value": "Source IP" }]
          },
          {
            "matcher": { "id": "byName", "options": "dst_port" },
            "properties": [{ "id": "displayName", "value": "Port" }]
          },
          {
            "matcher": { "id": "byName", "options": "logtype" },
            "properties": [{ "id": "displayName", "value": "Service" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{job=\"opencanary\"} | json | src_host != \"\"",
          "queryType": "range",
          "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "source": "labels" } },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "src_host": "Source IP",
              "dst_port": "Port",
              "logtype": "Service Type"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Top Source IPs (24h)",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 12 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" },
        "xField": "src_host"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (src_host) (count_over_time({job=\"opencanary\"} | json | src_host != \"\" [24h]))",
          "legendFormat": "{{src_host}}",
          "queryType": "instant"
        }
      ]
    }
  ]
}
